{
  "name": "car-tools-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "vite build && node scripts/prerender.mjs && npm run verify:static && node scripts/verify-fonts.mjs",
    "verify:static": "node scripts/validate-static-output.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@shakilabs/ui": "file:vendor/shakilabs-ui-0.2.2.tgz",
    "@sentry/vue": "^10.43.0",
    "@unhead/vue": "^2.1.12",
    "autoprefixer": "^10.4.24",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4",
    "postcss": "^8.5.6",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.25",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.0"
  }
}
